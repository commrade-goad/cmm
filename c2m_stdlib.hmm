extern const char *eval_template(const char *str);

#include <stddef.h>
#include <stdint.h>

typedef enum {
  __TYPE_VOID,
  __TYPE_BOOL,
  __TYPE_CHAR,
  __TYPE_SCHAR,
  __TYPE_UCHAR,
  __TYPE_SHORT,
  __TYPE_USHORT,
  __TYPE_INT,
  __TYPE_UINT,
  __TYPE_LONG,
  __TYPE_ULONG,
  __TYPE_LLONG,
  __TYPE_ULLONG,
  __TYPE_FLOAT,
  __TYPE_DOUBLE,
  __TYPE_LDOUBLE,
  __TYPE_PTR,
  __TYPE_ENUM,
  __TYPE_STRUCT,
  __TYPE_UNION,
  __TYPE_ARRAY,
  __TYPE_FUNC,
} __type_kind;

#define __TYPE_MAX_FIELDS  64
#define __TYPE_MAX_MEMBERS 64

typedef struct __type_t {
  char         name[64];
  size_t       size;
  size_t       align;
  __type_kind  kind;
  int          field_count;
  int          member_count;
  char         field_names[__TYPE_MAX_FIELDS][32];
  char         field_types[__TYPE_MAX_FIELDS][64];
  int32_t      field_offsets[__TYPE_MAX_FIELDS];
  char         member_names[__TYPE_MAX_MEMBERS][32];
  int32_t      member_values[__TYPE_MAX_MEMBERS];
} __type_t;

#include <stdlib.h>
#include <string.h>
#include <assert.h>

/* Opaque type-safe box: pointer + type descriptor */
typedef struct {
  void          *data;
  const __type_t *type;
} Opaque;

/* Wrap a value in an Opaque (infer type automatically).
 * Note: `x` is evaluated twice by this expansion (once for its address,
 * once for __type_of), so avoid side effects in the argument, e.g.
 * opaque(arr[j++]) will increment j twice. A version using a
 * statement-expression temporary to fix that was considered and
 * rejected: da_push stores the whole (pointer, type) pair for later use
 * rather than copying bytes out immediately, so `.data` has to point at
 * something that outlives the call -- a temporary local to the
 * statement-expression does not. */
#define opaque(x) ((Opaque){ &(x), __type_of(x) })

/* Runtime type assertion — compares kind + size + name (pointer not reliable) */
#define assert_type(o, T) do { \
    const __type_t *_t1 = (o).type; \
    const __type_t *_t2 = __type_of (T); \
    assert (_t1->kind == _t2->kind && _t1->size == _t2->size \
            && strcmp (_t1->name, _t2->name) == 0); \
  } while (0)

/* DynamicArray of Opaque items with uniform element type */
typedef struct {
  Opaque        *items;
  int            count;
  int            capacity;
  const __type_t *element_type;
} DynamicArray;

static DynamicArray da_create (const __type_t *t) {
  DynamicArray da = {NULL, 0, 0, t};
  return da;
}

static void da_destroy (DynamicArray *da) {
  free (da->items);
  da->items = NULL;
  da->count = da->capacity = 0;
}

static void da_push_impl (DynamicArray *da, Opaque val) {
  assert (val.type->kind == da->element_type->kind
          && val.type->size == da->element_type->size
          && strcmp (val.type->name, da->element_type->name) == 0);
  if (da->count >= da->capacity) {
    int new_cap = da->capacity ? da->capacity * 2 : 4;
    da->items = realloc (da->items, (size_t) new_cap * sizeof (Opaque));
    da->capacity = new_cap;
  }
  da->items[da->count++] = val;
}

/* da_push(da, val) -- val is auto-boxed, no need to write opaque(val)
 * yourself. Note val is evaluated twice (see opaque()'s own caveat
 * above); avoid side effects in it. */
#define da_push(da, val) da_push_impl ((da), opaque (val))

static Opaque *da_get (DynamicArray *da, int i) {
  assert (i >= 0 && i < da->count);
  return &da->items[i];
}

/* --- Open-addressing HashMap with inline key/value storage --- */

static uint64_t hm_hash (const void *data, size_t len) {
  const unsigned char *p = data;
  uint64_t h = 14695981039346656037ULL;
  for (size_t i = 0; i < len; i++)
    h = (h ^ p[i]) * 1099511628211ULL;
  return h;
}

typedef struct {
  uint8_t    *slots;       /* 0=empty 1=occupied 2=tombstone */
  uint8_t    *keys;
  uint8_t    *values;
  int         count;
  int         capacity;
  const __type_t *key_type;
  const __type_t *value_type;
} HashMap;

static void hm_resize (HashMap *hm);

static HashMap hm_create (const __type_t *kt, const __type_t *vt) {
  HashMap hm = {0};
  hm.key_type = kt;
  hm.value_type = vt;
  hm.capacity = 8;
  hm.slots = calloc ((size_t) hm.capacity, 1);
  hm.keys = malloc ((size_t) hm.capacity * kt->size);
  hm.values = malloc ((size_t) hm.capacity * vt->size);
  return hm;
}

static void hm_destroy (HashMap *hm) {
  free (hm->slots);  hm->slots = NULL;
  free (hm->keys);   hm->keys = NULL;
  free (hm->values); hm->values = NULL;
  hm->count = hm->capacity = 0;
}

static void hm_set_impl (HashMap *hm, Opaque key, Opaque value) {
  assert (key.type->kind == hm->key_type->kind && key.type->size == hm->key_type->size
          && strcmp (key.type->name, hm->key_type->name) == 0);
  assert (value.type->kind == hm->value_type->kind && value.type->size == hm->value_type->size
          && strcmp (value.type->name, hm->value_type->name) == 0);
  if ((hm->count + 1) * 4 >= hm->capacity * 3) hm_resize (hm);
  size_t ksize = hm->key_type->size, vsize = hm->value_type->size;
  uint64_t hash = hm_hash (key.data, ksize);
  int mask = hm->capacity - 1;
  for (int i = 0;; i++) {
    int idx = (int) (hash + i) & mask;
    if (hm->slots[idx] == 0 || hm->slots[idx] == 2) {
      hm->slots[idx] = 1;
      memcpy (&hm->keys[idx * ksize],  key.data,  ksize);
      memcpy (&hm->values[idx * vsize], value.data, vsize);
      hm->count++;
      return;
    }
    if (hm->slots[idx] == 1 && memcmp (&hm->keys[idx * ksize], key.data, ksize) == 0) {
      memcpy (&hm->values[idx * vsize], value.data, vsize);
      return;
    }
  }
}

/* hm_set(hm, key, value) -- key and value are auto-boxed, no need to
 * write opaque(...) yourself. Both are evaluated twice (see opaque()'s
 * caveat above); avoid side effects in them. */
#define hm_set(hm, key, value) hm_set_impl ((hm), opaque (key), opaque (value))

static void *hm_get_impl (HashMap *hm, Opaque key) {
  size_t ksize = hm->key_type->size;
  uint64_t hash = hm_hash (key.data, ksize);
  int mask = hm->capacity - 1;
  for (int i = 0; i < hm->capacity; i++) {
    int idx = (int) (hash + i) & mask;
    if (hm->slots[idx] == 0) return NULL;
    if (hm->slots[idx] == 1 && memcmp (&hm->keys[idx * ksize], key.data, ksize) == 0)
      return &hm->values[idx * hm->value_type->size];
  }
  return NULL;
}

#define hm_get(hm, key) hm_get_impl ((hm), opaque (key))

static int hm_has_impl (HashMap *hm, Opaque key) {
  return hm_get_impl (hm, key) != NULL;
}

#define hm_has(hm, key) hm_has_impl ((hm), opaque (key))

static void hm_remove_impl (HashMap *hm, Opaque key) {
  size_t ksize = hm->key_type->size;
  uint64_t hash = hm_hash (key.data, ksize);
  int mask = hm->capacity - 1;
  for (int i = 0; i < hm->capacity; i++) {
    int idx = (int) (hash + i) & mask;
    if (hm->slots[idx] == 0) return;
    if (hm->slots[idx] == 1 && memcmp (&hm->keys[idx * ksize], key.data, ksize) == 0) {
      hm->slots[idx] = 2;
      hm->count--;
      return;
    }
  }
}

#define hm_remove(hm, key) hm_remove_impl ((hm), opaque (key))

static void hm_resize (HashMap *hm) {
  int old_cap = hm->capacity;
  uint8_t *old_slots = hm->slots;
  uint8_t *old_keys = hm->keys;
  uint8_t *old_values = hm->values;
  size_t ksize = hm->key_type->size, vsize = hm->value_type->size;

  hm->capacity = old_cap * 2;
  hm->slots = calloc ((size_t) hm->capacity, 1);
  hm->keys  = malloc ((size_t) hm->capacity * ksize);
  hm->values = malloc ((size_t) hm->capacity * vsize);
  hm->count = 0;

  for (int i = 0; i < old_cap; i++)
    if (old_slots[i] == 1)
      hm_set_impl (hm, (Opaque){ &old_keys[i * ksize], hm->key_type },
                       (Opaque){ &old_values[i * vsize], hm->value_type });
  free (old_slots); free (old_keys); free (old_values);
}

/* --- String (resizable, null-terminated) --- */

typedef struct {
  char  *data;
  int    count;     /* length of string (excluding null) */
  int    capacity;  /* allocated bytes (≥ count+1) */
} String;

static String str_new (void) {
  String s = {0};
  s.capacity = 16;
  s.data = malloc ((size_t) s.capacity);
  s.data[0] = '\0';
  return s;
}

static String str_from (const char *cstr) {
  int len = (int) strlen (cstr);
  String s = {0};
  s.count = len;
  s.capacity = len + 16;
  s.data = malloc ((size_t) s.capacity);
  memcpy (s.data, cstr, (size_t) len + 1);
  return s;
}

static void str_destroy (String *s) {
  free (s->data);
  s->data = NULL;
  s->count = s->capacity = 0;
}

static void str_ensure_cap (String *s, int need) {
  if (need <= s->capacity) return;
  int new_cap = s->capacity ? s->capacity : 16;
  while (new_cap < need) new_cap *= 2;
  s->data = realloc (s->data, (size_t) new_cap);
  s->capacity = new_cap;
}

static void str_append (String *s, const char *suffix) {
  int slen = (int) strlen (suffix);
  if (slen == 0) return;
  str_ensure_cap (s, s->count + slen + 1);
  memcpy (s->data + s->count, suffix, (size_t) slen + 1);
  s->count += slen;
}

static void str_append_char (String *s, char c) {
  str_ensure_cap (s, s->count + 2);
  s->data[s->count] = c;
  s->data[s->count + 1] = '\0';
  s->count++;
}

static void str_clear (String *s) {
  if (s->data != NULL) s->data[0] = '\0';
  s->count = 0;
}

static const char *str_cstr (const String *s) {
  return s->data;
}

