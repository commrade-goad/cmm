extern const char *eval_template(const char *str);

#include <stddef.h>
#include <stdint.h>

typedef enum {
  __TYPE_VOID,
  __TYPE_BOOL,
  __TYPE_CHAR,
  __TYPE_SCHAR,
  __TYPE_UCHAR,
  __TYPE_SHORT,
  __TYPE_USHORT,
  __TYPE_INT,
  __TYPE_UINT,
  __TYPE_LONG,
  __TYPE_ULONG,
  __TYPE_LLONG,
  __TYPE_ULLONG,
  __TYPE_FLOAT,
  __TYPE_DOUBLE,
  __TYPE_LDOUBLE,
  __TYPE_PTR,
  __TYPE_ENUM,
  __TYPE_STRUCT,
  __TYPE_UNION,
  __TYPE_ARRAY,
  __TYPE_FUNC,
} __type_kind;

#define __TYPE_MAX_FIELDS  64
#define __TYPE_MAX_MEMBERS 64

typedef struct __type_t {
  char         name[64];
  size_t       size;
  size_t       align;
  __type_kind  kind;
  int          field_count;
  int          member_count;
  char         field_names[__TYPE_MAX_FIELDS][32];
  char         field_types[__TYPE_MAX_FIELDS][64];
  int32_t      field_offsets[__TYPE_MAX_FIELDS];
  char         member_names[__TYPE_MAX_MEMBERS][32];
  int32_t      member_values[__TYPE_MAX_MEMBERS];
} __type_t;

#include <stdlib.h>
#include <string.h>
#include <assert.h>

/* Opaque type-safe box: pointer + type descriptor */
typedef struct {
  void          *data;
  const __type_t *type;
} Opaque;

/* Wrap a value in an Opaque (infer type automatically) */
#define opaque(x) ((Opaque){ &(x), __type_of(x) })

/* Runtime type assertion — compares kind + size + name (pointer not reliable) */
#define assert_type(o, T) do { \
    const __type_t *_t1 = (o).type; \
    const __type_t *_t2 = __type_of (T); \
    assert (_t1->kind == _t2->kind && _t1->size == _t2->size \
            && strcmp (_t1->name, _t2->name) == 0); \
  } while (0)

/* DynamicArray of Opaque items with uniform element type */
typedef struct {
  Opaque        *items;
  int            count;
  int            capacity;
  const __type_t *element_type;
} DynamicArray;

static DynamicArray da_create (const __type_t *t) {
  DynamicArray da = {NULL, 0, 0, t};
  return da;
}

static void da_destroy (DynamicArray *da) {
  free (da->items);
  da->items = NULL;
  da->count = da->capacity = 0;
}

static void da_push (DynamicArray *da, Opaque val) {
  assert (val.type->kind == da->element_type->kind
          && val.type->size == da->element_type->size
          && strcmp (val.type->name, da->element_type->name) == 0);
  if (da->count >= da->capacity) {
    int new_cap = da->capacity ? da->capacity * 2 : 4;
    da->items = realloc (da->items, (size_t) new_cap * sizeof (Opaque));
    da->capacity = new_cap;
  }
  da->items[da->count++] = val;
}

static Opaque *da_get (DynamicArray *da, int i) {
  assert (i >= 0 && i < da->count);
  return &da->items[i];
}

/* --- Open-addressing HashMap with inline key/value storage --- */

static uint64_t hm_hash (const void *data, size_t len) {
  const unsigned char *p = data;
  uint64_t h = 14695981039346656037ULL;
  for (size_t i = 0; i < len; i++)
    h = (h ^ p[i]) * 1099511628211ULL;
  return h;
}

typedef struct {
  uint8_t    *slots;       /* 0=empty 1=occupied 2=tombstone */
  uint8_t    *keys;
  uint8_t    *values;
  int         count;
  int         capacity;
  const __type_t *key_type;
  const __type_t *value_type;
} HashMap;

static void hm_resize (HashMap *hm);

static HashMap hm_create (const __type_t *kt, const __type_t *vt) {
  HashMap hm = {0};
  hm.key_type = kt;
  hm.value_type = vt;
  hm.capacity = 8;
  hm.slots = calloc ((size_t) hm.capacity, 1);
  hm.keys = malloc ((size_t) hm.capacity * kt->size);
  hm.values = malloc ((size_t) hm.capacity * vt->size);
  return hm;
}

static void hm_destroy (HashMap *hm) {
  free (hm->slots);  hm->slots = NULL;
  free (hm->keys);   hm->keys = NULL;
  free (hm->values); hm->values = NULL;
  hm->count = hm->capacity = 0;
}

static void hm_set (HashMap *hm, Opaque key, Opaque value) {
  assert (key.type->kind == hm->key_type->kind && key.type->size == hm->key_type->size
          && strcmp (key.type->name, hm->key_type->name) == 0);
  assert (value.type->kind == hm->value_type->kind && value.type->size == hm->value_type->size
          && strcmp (value.type->name, hm->value_type->name) == 0);
  if ((hm->count + 1) * 4 >= hm->capacity * 3) hm_resize (hm);
  size_t ksize = hm->key_type->size, vsize = hm->value_type->size;
  uint64_t hash = hm_hash (key.data, ksize);
  int mask = hm->capacity - 1;
  for (int i = 0;; i++) {
    int idx = (int) (hash + i) & mask;
    if (hm->slots[idx] == 0 || hm->slots[idx] == 2) {
      hm->slots[idx] = 1;
      memcpy (&hm->keys[idx * ksize],  key.data,  ksize);
      memcpy (&hm->values[idx * vsize], value.data, vsize);
      hm->count++;
      return;
    }
    if (hm->slots[idx] == 1 && memcmp (&hm->keys[idx * ksize], key.data, ksize) == 0) {
      memcpy (&hm->values[idx * vsize], value.data, vsize);
      return;
    }
  }
}

static void *hm_get (HashMap *hm, Opaque key) {
  size_t ksize = hm->key_type->size;
  uint64_t hash = hm_hash (key.data, ksize);
  int mask = hm->capacity - 1;
  for (int i = 0; i < hm->capacity; i++) {
    int idx = (int) (hash + i) & mask;
    if (hm->slots[idx] == 0) return NULL;
    if (hm->slots[idx] == 1 && memcmp (&hm->keys[idx * ksize], key.data, ksize) == 0)
      return &hm->values[idx * hm->value_type->size];
  }
  return NULL;
}

static int hm_has (HashMap *hm, Opaque key) {
  return hm_get (hm, key) != NULL;
}

static void hm_remove (HashMap *hm, Opaque key) {
  size_t ksize = hm->key_type->size;
  uint64_t hash = hm_hash (key.data, ksize);
  int mask = hm->capacity - 1;
  for (int i = 0; i < hm->capacity; i++) {
    int idx = (int) (hash + i) & mask;
    if (hm->slots[idx] == 0) return;
    if (hm->slots[idx] == 1 && memcmp (&hm->keys[idx * ksize], key.data, ksize) == 0) {
      hm->slots[idx] = 2;
      hm->count--;
      return;
    }
  }
}

static void hm_resize (HashMap *hm) {
  int old_cap = hm->capacity;
  uint8_t *old_slots = hm->slots;
  uint8_t *old_keys = hm->keys;
  uint8_t *old_values = hm->values;
  size_t ksize = hm->key_type->size, vsize = hm->value_type->size;

  hm->capacity = old_cap * 2;
  hm->slots = calloc ((size_t) hm->capacity, 1);
  hm->keys  = malloc ((size_t) hm->capacity * ksize);
  hm->values = malloc ((size_t) hm->capacity * vsize);
  hm->count = 0;

  for (int i = 0; i < old_cap; i++)
    if (old_slots[i] == 1)
      hm_set (hm, (Opaque){ &old_keys[i * ksize], hm->key_type },
                  (Opaque){ &old_values[i * vsize], hm->value_type });
  free (old_slots); free (old_keys); free (old_values);
}
