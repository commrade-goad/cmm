extern const char *eval_template(const char *str);

#include <stddef.h>
#include <stdint.h>

typedef enum {
  __TYPE_VOID,
  __TYPE_BOOL,
  __TYPE_CHAR,
  __TYPE_SCHAR,
  __TYPE_UCHAR,
  __TYPE_SHORT,
  __TYPE_USHORT,
  __TYPE_INT,
  __TYPE_UINT,
  __TYPE_LONG,
  __TYPE_ULONG,
  __TYPE_LLONG,
  __TYPE_ULLONG,
  __TYPE_FLOAT,
  __TYPE_DOUBLE,
  __TYPE_LDOUBLE,
  __TYPE_PTR,
  __TYPE_ENUM,
  __TYPE_STRUCT,
  __TYPE_UNION,
  __TYPE_ARRAY,
  __TYPE_FUNC,
} __type_kind;

#define __TYPE_MAX_FIELDS  64
#define __TYPE_MAX_MEMBERS 64

typedef struct __type_t {
  char         name[64];
  size_t       size;
  size_t       align;
  __type_kind  kind;
  int          field_count;
  int          member_count;
  char         field_names[__TYPE_MAX_FIELDS][32];
  char         field_types[__TYPE_MAX_FIELDS][64];
  int32_t      field_offsets[__TYPE_MAX_FIELDS];
  char         member_names[__TYPE_MAX_MEMBERS][32];
  int32_t      member_values[__TYPE_MAX_MEMBERS];
} __type_t;

#include <stdlib.h>
#include <string.h>
#include <assert.h>

/* Opaque type-safe box: pointer + type descriptor */
typedef struct {
  void          *data;
  const __type_t *type;
} Opaque;

/* Wrap a value in an Opaque (infer type automatically) */
#define opaque(x) ((Opaque){ &(x), __type_of(x) })

/* Runtime type assertion — compares kind + size + name (pointer not reliable) */
#define assert_type(o, T) do { \
    const __type_t *_t1 = (o).type; \
    const __type_t *_t2 = __type_of (T); \
    assert (_t1->kind == _t2->kind && _t1->size == _t2->size \
            && strcmp (_t1->name, _t2->name) == 0); \
  } while (0)

/* DynamicArray of Opaque items with uniform element type */
typedef struct {
  Opaque        *items;
  int            count;
  int            capacity;
  const __type_t *element_type;
} DynamicArray;

static DynamicArray da_create (const __type_t *t) {
  DynamicArray da = {NULL, 0, 0, t};
  return da;
}

static void da_destroy (DynamicArray *da) {
  free (da->items);
  da->items = NULL;
  da->count = da->capacity = 0;
}

static void da_push (DynamicArray *da, Opaque val) {
  assert (val.type->kind == da->element_type->kind
          && val.type->size == da->element_type->size
          && strcmp (val.type->name, da->element_type->name) == 0);
  if (da->count >= da->capacity) {
    int new_cap = da->capacity ? da->capacity * 2 : 4;
    da->items = realloc (da->items, (size_t) new_cap * sizeof (Opaque));
    da->capacity = new_cap;
  }
  da->items[da->count++] = val;
}

static Opaque *da_get (DynamicArray *da, int i) {
  assert (i >= 0 && i < da->count);
  return &da->items[i];
}
